# ==========================================
# REQUIRED - Must configure these
# ==========================================

# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/your_db_name"
# Admin connection for database creation (usually just change dbname to 'postgres')
DATABASE_ADMIN_URL="postgresql://postgres:postgres@localhost:5432/postgres"
# Test database — MUST be a separate database from DATABASE_URL.
# Integration tests reset this DB on each run; pointing it at a real DB will destroy data.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arena_test"

# JWT Secrets (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-32-character-secret-change-this-in-production-now
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_SECRET=your-32-character-refresh-secret-change-this-now
JWT_REFRESH_TOKEN_TTL_DAYS=30

# App Settings
NODE_ENV=development
ENVIRONMENT_NAME=dev
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:19006

# Security
BCRYPT_ROUNDS=10

# ==========================================
# OPTIONAL - Only add if you need them
# ==========================================

# AWS S3 (Uncomment if you need file storage)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name

# SMTP (Uncomment if you need email service)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourcompany.com

# OTP/SMS Service
# OTP_MODE: console | test_pair | live
# - console: logs OTP to console
# - test_pair: uses fixed test phone + code
# - live: sends real SMS
OTP_MODE=console
OTP_TEST_PHONE=
OTP_TEST_CODE=
SMS_PROVIDER_API_KEY=

# Payment Provider (Phase 7)
# PAYMENT_MODE: manual | live
# - manual: stateless; admin records out-of-band payments and marks bookings
#           paid via the admin endpoint. No external network calls.
# - live: stub that throws — wire a real provider (QiCard, Tabadul, Areeba)
#         in a later ops phase before flipping this on in production.
PAYMENT_MODE=manual

# Push notification delivery (Phase 8)
# PUSH_MODE: console | live
# - console: logs deliveries to stdout, always succeeds. Default for dev.
# - live: stub that throws — wire FCM / APNs / OneSignal in a later phase.
PUSH_MODE=console

# Scheduler (Phase 8)
# Set to false to disable the in-process cron runner (used by tests).
SCHEDULER_ENABLED=true

# Two-Factor Authentication (TOTP)
# Enabled by default (no external service needed)
# Set to false to disable
ENABLE_2FA=true
TWO_FACTOR_ISSUER=YourCompany
APP_NAME=Clean Architecture App

# Admin Bootstrap
ADMIN_BOOTSTRAP_TOKEN=
