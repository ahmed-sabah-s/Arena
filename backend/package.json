{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx database/migrate.ts",
    "db:migrate:dry": "tsx database/migrate.ts --dry-run",
    "db:seed": "tsx database/seeds/seed-runner.ts",
    "db:reset": "tsx database/reset.ts && pnpm db:migrate && pnpm db:seed",
    "db:test:reset": "tsx database/test-reset.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Clean Architecture Backend Template",
  "dependencies": {
    "@arena/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/s3-presigned-post": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.709.0",
    "@trpc/server": "^11.10.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.17",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
